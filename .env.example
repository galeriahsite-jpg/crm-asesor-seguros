# ============================================================
# LUMO · Variables de entorno
# Copia este archivo a .env.local para desarrollo y configura
# los mismos nombres en Vercel → Settings → Environment Variables.
# ============================================================

# Supabase (públicas: van al navegador; los permisos reales los da RLS)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase service role (SECRETA: solo servidor, jamás en el frontend)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (SECRETA)
OPENAI_API_KEY=

# UUID del asesor dueño de los leads del embudo público
# (Supabase → Authentication → Users → copia tu ID)
LUMO_LEAD_OWNER_ID=

# Opcionales: modelo de IA (default gpt-4o-mini)
# LUMO_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
